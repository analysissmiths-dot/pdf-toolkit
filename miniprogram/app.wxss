/* Global styles */
page {
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", "PingFang SC", sans-serif;
  background: #f8fafc;
  color: #0f172a;
  font-size: 28rpx;
  line-height: 1.6;
}

.container {
  padding: 30rpx;
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  border: 2rpx solid #e2e8f0;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.btn-primary {
  background: #2563eb;
  color: #fff;
  border: none;
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  font-size: 28rpx;
  font-weight: 500;
  width: 100%;
  text-align: center;
  margin-top: 20rpx;
}

.btn-primary:active {
  background: #1d4ed8;
}

.btn-primary[disabled] {
  opacity: 0.5;
}

.btn-ghost {
  background: transparent;
  color: #64748b;
  border: 2rpx solid #e2e8f0;
  border-radius: 16rpx;
  padding: 20rpx 30rpx;
  font-size: 26rpx;
  width: 100%;
  text-align: center;
}

.text-muted {
  color: #94a3b8;
  font-size: 24rpx;
}

.text-center {
  text-align: center;
}

.badge {
  display: inline-block;
  font-size: 22rpx;
  font-weight: 600;
  padding: 6rpx 16rpx;
  border-radius: 30rpx;
}

.badge-free {
  background: #dbeafe;
  color: #1d4ed8;
}

.badge-pro {
  background: #fef3c7;
  color: #92400e;
}

.badge-unlocked {
  background: #dcfce7;
  color: #166534;
}

.drop-zone {
  border: 4rpx dashed #e2e8f0;
  border-radius: 20rpx;
  padding: 60rpx 30rpx;
  text-align: center;
  background: #fafafa;
  margin-bottom: 24rpx;
}

.drop-zone-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.file-list {
  margin-bottom: 24rpx;
}

.file-item {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.file-name {
  flex: 1;
  font-size: 26rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.file-size {
  font-size: 22rpx;
  color: #94a3b8;
  margin-left: 16rpx;
}

.progress-bar {
  height: 8rpx;
  background: #e2e8f0;
  border-radius: 8rpx;
  overflow: hidden;
  margin: 24rpx 0;
}

.progress-inner {
  height: 100%;
  background: #2563eb;
  width: 0%;
  transition: width 0.3s;
}

.page-title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.page-desc {
  font-size: 26rpx;
  color: #64748b;
  margin-bottom: 32rpx;
}
