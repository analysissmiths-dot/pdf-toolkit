.split-inputs {
  display: flex;
  gap: 24rpx;
  margin: 24rpx 0;
}

.input-group {
  flex: 1;
}

.input-label {
  font-size: 24rpx;
  font-weight: 500;
  display: block;
  margin-bottom: 8rpx;
}

.input {
  background: #fff;
  border: 2rpx solid #e2e8f0;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
}

.action-row {
  display: flex;
  gap: 16rpx;
}
