.page-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin: 20rpx 0;
}

.page-card {
  width: calc(50% - 8rpx);
  background: #fff;
  border: 2rpx solid #e2e8f0;
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
  position: relative;
  box-sizing: border-box;
}

.page-card.deleted {
  border-color: #dc2626;
  background: #fef2f2;
  opacity: 0.7;
}

.page-num { font-size: 24rpx; color: #64748b; margin-bottom: 8rpx; }
.page-icon { font-size: 48rpx; }
.deleted-badge {
  font-size: 20rpx; color: #dc2626; font-weight: 600;
  margin-top: 8rpx;
}
