.hero {
  text-align: center;
  padding: 40rpx 0 30rpx;
}

.hero-title {
  font-size: 44rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 12rpx;
}

.hero-desc {
  font-size: 28rpx;
  color: #64748b;
}

.tools-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 20rpx;
}

.tool-card {
  width: calc(50% - 10rpx);
  background: #fff;
  border: 2rpx solid #e2e8f0;
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
  box-sizing: border-box;
}

.tool-card:active {
  border-color: #2563eb;
}

.tool-icon {
  font-size: 64rpx;
  margin-bottom: 12rpx;
}

.tool-name {
  font-size: 30rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 8rpx;
}

.tool-desc {
  font-size: 24rpx;
  color: #64748b;
  display: block;
  margin-bottom: 12rpx;
  line-height: 1.4;
}

.pro-section {
  margin-top: 40rpx;
  background: linear-gradient(135deg, #2563eb, #1d4ed8);
  border-radius: 24rpx;
  padding: 40rpx;
  text-align: center;
}

.pro-section:active {
  opacity: 0.9;
}

.pro-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  margin-bottom: 8rpx;
}

.pro-desc {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  display: block;
  margin-bottom: 12rpx;
}

.pro-link {
  font-size: 28rpx;
  color: #fbbf24;
  font-weight: 500;
}
