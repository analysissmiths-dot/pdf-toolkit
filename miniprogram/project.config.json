{
  "description": "PDFKit - Privacy-first PDF Toolkit",
  "packOptions": { "ignore": [], "include": [] },
  "setting": {
    "bundle": false,
    "userConfirmedBundleSwitch": false,
    "urlCheck": true,
    "scopeDataCheck": false,
    "coverView": true,
    "es6": true,
    "postcss": true,
    "compileHotReLoad": false,
    "lazyloadPlaceholderEnable": false,
    "preloadBackgroundData": false,
    "minified": true,
    "autoAudits": false,
    "newFeature": false,
    "uglifyFileName": false,
    "uploadWithSourceMap": true,
    "useIsolateContext": true,
    "nodeModules": true,
    "enhance": true,
    "useMultiFrameRuntime": true,
    "showShadowRootInWxmlPanel": true,
    "packNpmManually": true,
    "packNpmRelationList": [
      { "packageJsonPath": "./package.json", "miniprogramNpmDistDir": "./" }
    ],
    "minifyWXSS": true,
    "disableSWStrictMode": true,
    "minifyWXML": true,
    "useStaticServer": true,
    "showES6CompileOption": false,
    "checkInvalidKey": true,
    "enableEngine": true
  },
  "compileType": "miniprogram",
  "libVersion": "3.7.9",
  "appid": "YOUR_APPID",
  "projectname": "PDFKit",
  "debugOptions": { "hidedInDevtools": [] },
  "scripts": {},
  "staticServerOptions": { "basePath": "", "servePath": "" },
  "condition": { "search": { "current": -1, "list": [] }, "conversation": { "current": -1, "list": [] }, "plugin": { "current": -1, "list": [] }, "game": { "currentL": -1, "list": [] }, "result": { "current": -1, "list": [] }, "miniprogram": { "current": -1, "list": [] } }
}
